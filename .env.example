# ==============================================================================
# 🧠 MATRYCA BRAIN OS - LOCAL ENVIRONMENT CONFIGURATION (.env.example)
# ==============================================================================
# Instructions: Copy this file to ".env", remove example placeholders,
# and adapt paths and models to your local infrastructure setup.

# ------------------------------------------------------------------------------
# 📁 1. CORE CONFIGURATION & FILE PLANE
# ------------------------------------------------------------------------------
# Absolute path to the root directory of your local Logseq OG graph.
LOGSEQ_GRAPH_PATH="/absolute/path/to/your/logseq/graph"

# Opt-in to automatically execute 'git add -A' and 'git commit' before selected writes.
# Highly useful when using Matryca as an interactive MCP server (Claude/Cursor).
MATRYCA_GIT_SNAPSHOT_ON_WRITE=false

# Enable advanced debugging to output raw, uncensored logs for troubleshooting.
MATRYCA_DEBUG=false

# ------------------------------------------------------------------------------
# 🤖 2. LOCAL LLM CONFIGURATION (LM Studio / Local Inference Server)
# ------------------------------------------------------------------------------
# The local HTTP endpoint of your inference server (LM Studio defaults to port 1234).
MATRYCA_LM_BASE_URL="http://localhost:1234/v1"

# EXACT name of the model currently loaded in LM Studio (e.g., "gemma-4-e4b-it", "qwen3.5-9b-instruct").
# NOTE: Must match perfectly to prevent hardcoded configuration leakage!
MATRYCA_LM_MODEL="gemma-4-e4b-it"

# Primary structured output extraction mode.
# "JSON_SCHEMA" leverages native grammar-based sampling in LM Studio (ultra-fast and precise).
MATRYCA_LM_INSTRUCTOR_MODE="JSON_SCHEMA"

# Fallback strategy if the primary mode fails structured parsing or validation.
MATRYCA_LM_INSTRUCTOR_FALLBACK="MD_JSON"

# ------------------------------------------------------------------------------
# ⏳ 3. MAINTENANCE DAEMON TIMING & LOGGING
# ------------------------------------------------------------------------------
# Interval in seconds between full graph scans looking for modified/pending files.
MATRYCA_BRAIN_POLL_SECONDS=30

# Path where the daemon logs token transactions, latencies, and operations.
MATRYCA_BRAIN_LOG_PATH="logs/matryca_brain_ops.log"

# ------------------------------------------------------------------------------
# 🛡️ 4. MEMORY & CONTEXT PROTECTION (Ermes Context Compressor Mode)
# ------------------------------------------------------------------------------
# Active rolling compression of multi-turn history to prevent local KV-Cache saturation.
MATRYCA_BRAIN_CONTEXT_COMPRESSION=true

# The critical prompt token threshold that triggers the rolling history condensation linter.
MATRYCA_BRAIN_COMPRESSION_TRIGGER_TOKENS=100000

# The target token length to reduce the context window to after epistemic state condensation.
MATRYCA_BRAIN_COMPRESSION_TARGET_TOKENS=30000

# ------------------------------------------------------------------------------
# 🛠️ 5. COGNITIVE LINTING MODULES (Open Source Tier - Disabled by Default)
# ------------------------------------------------------------------------------
# Module 1: Automatically heals dangling links by generating contextual seed definitions.
MATRYCA_LINT_HEAL_DANGLING=false
MATRYCA_LINT_DANGLING_MAX_WORDS=50

# Module 2: Assesses semantic overlap and enforces alias properties to avoid duplicate entities.
MATRYCA_LINT_ENTITY_CONSOLIDATION=false
MATRYCA_LINT_SIMILARITY_THRESHOLD=0.85

# Module 3: Extracts dense sub-trees into distinct atomic pages, replacing them with clean links.
MATRYCA_LINT_AUTO_SPLIT=false
MATRYCA_LINT_SPLIT_BLOCK_THRESHOLD=15

# Module 4: Enforces tag property hygiene (e.g., status and deadline fields for #project).
MATRYCA_LINT_PROPERTY_HYGIENE=false
MATRYCA_LINT_INFER_MISSING_PROPERTIES=false

# Companion Modules: Manage link backpropagation and semantic context routing on disk.
MATRYCA_LINT_BACKPROPAGATE_LINKS=false
MATRYCA_LINT_SEMANTIC_ROUTING=false

# ------------------------------------------------------------------------------
# 🌌 6. SOVEREIGN ONTOLOGY MARPA (Proprietary Framework - Disabled by Default)
# ------------------------------------------------------------------------------
# Classifies pages strictly into Mappa, Area, Risorsa, Progetto, or Archivio domains.
MATRYCA_LINT_MARPA_FRAMEWORK=false

# ------------------------------------------------------------------------------
# 💎 7. ENTERPRISE PRO MODULES (Encrypted Commercial Tier - Architectural Reference)
# ------------------------------------------------------------------------------
# NOTE: These features are exclusively available via the Nuitka-compiled commercial app.
# Keep set to false in the open-source CLI engine.
MATRYCA_LINT_TWIN_INGESTION=false
MATRYCA_LINT_EPISTEMIC_GUARDIAN=false